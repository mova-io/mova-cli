<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1"/>
<title>Movate MDK — Demo</title>
<style>
  :root{--bg:#0b0e14;--card:#151a23;--line:#232b38;--fg:#e6edf3;--mut:#8b97a7;--pink:#ec4899;--blue:#60a5fa;--green:#34d399;--amber:#fbbf24;--red:#f87171}
  *{box-sizing:border-box}
  body{margin:0;background:radial-gradient(1200px 600px at 50% -10%,#16203a 0,var(--bg) 60%);color:var(--fg);font:16px/1.5 system-ui,-apple-system,Segoe UI,Roboto,sans-serif}
  .wrap{max-width:980px;margin:0 auto;padding:56px 24px 80px}
  .wrap.wide{max-width:1180px}
  h1{font-size:34px;margin:0 0 4px;letter-spacing:-.02em}
  .brand{display:flex;align-items:center;gap:16px;flex-wrap:wrap;margin:0 0 6px}
  .brand svg{height:52px;width:auto;display:block}
  .brand-badge{font-size:12px;color:var(--mut);border:1px solid var(--line);border-radius:999px;padding:4px 12px;letter-spacing:.06em;text-transform:uppercase}
  .sub{color:var(--mut);margin:0 0 36px}
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
  a.card{display:block;text-decoration:none;color:inherit;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:20px 22px;transition:.15s}
  a.card:hover{border-color:var(--pink);transform:translateY(-2px)}
  .card h2{margin:0 0 6px;font-size:18px}
  .card p{margin:0;color:var(--mut);font-size:14px}
  .tag{display:inline-block;margin-top:12px;font-size:12px;color:var(--blue);background:#11203a;border:1px solid #1e3354;border-radius:999px;padding:2px 10px}
  .note{margin-top:36px;padding:16px 18px;background:#15110f;border:1px solid #3a2a22;border-radius:12px;color:#d8b9a8;font-size:13px}
  code{background:#1d2430;padding:1px 6px;border-radius:6px;color:#e6edf3}
  .foot{margin-top:28px;color:var(--mut);font-size:13px}
  /* ---- Agent Control Plane (ADR 090) ---- */
  .cp-head{display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;margin:0 0 18px}
  .cp-head h1{font-size:26px}
  .back{color:var(--mut);text-decoration:none;font-size:14px}
  .back:hover{color:var(--fg)}
  .bar{display:flex;gap:10px;flex-wrap:wrap;align-items:center;margin:0 0 18px;padding:14px 16px;background:var(--card);border:1px solid var(--line);border-radius:12px}
  .bar input{flex:1;min-width:240px;background:#0d1117;border:1px solid var(--line);border-radius:8px;color:var(--fg);padding:8px 11px;font:14px/1.4 ui-monospace,SFMono-Regular,Menlo,monospace}
  .btn{cursor:pointer;border:1px solid var(--line);background:#1d2430;color:var(--fg);border-radius:8px;padding:7px 13px;font-size:13px;transition:.12s}
  .btn:hover{border-color:var(--pink)}
  .btn.sm{padding:4px 9px;font-size:12px}
  .btn.on{border-color:var(--green);color:var(--green)}
  table{width:100%;border-collapse:collapse;font-size:14px}
  th,td{text-align:left;padding:11px 12px;border-bottom:1px solid var(--line);vertical-align:middle}
  th{color:var(--mut);font-weight:600;font-size:12px;text-transform:uppercase;letter-spacing:.05em}
  tr:hover td{background:#11161f}
  .pill{display:inline-block;font-size:12px;border-radius:999px;padding:2px 10px;border:1px solid var(--line)}
  .pill.active{color:var(--green);border-color:#1c5141;background:#0e1f1a}
  .pill.deprecated{color:var(--amber);border-color:#5a4a1a;background:#1f1a0e}
  .pill.disabled{color:var(--mut);background:#15171d}
  .pill.healthy{color:var(--green);border-color:#1c5141}
  .pill.unhealthy{color:var(--red);border-color:#5a2222;background:#1f1010}
  .pill.unknown{color:var(--mut)}
  .actions{display:flex;gap:6px;flex-wrap:wrap}
  .msg{margin:0 0 14px;padding:10px 14px;border-radius:10px;font-size:13px;display:none}
  .msg.err{display:block;background:#1f1010;border:1px solid #5a2222;color:#f6b1b1}
  .msg.ok{display:block;background:#0e1f1a;border:1px solid #1c5141;color:#a7e7cf}
  .muted{color:var(--mut)}
  #cp{display:none}
</style>
</head>
<body>
<!-- ===================== HOME (tile index) ===================== -->
<div class="wrap" id="home">
  <div class="brand">
    <svg viewBox="0 0 380 100" role="img" aria-label="mova io">
      <defs>
        <linearGradient id="movaio" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#ec4899"/>
          <stop offset=".5" stop-color="#f97316"/>
          <stop offset="1" stop-color="#fbbf24"/>
        </linearGradient>
      </defs>
      <text x="0" y="74" font-family="system-ui,'Segoe UI',Roboto,sans-serif" font-weight="800" font-size="84" letter-spacing="-2" fill="var(--fg)">mova</text>
      <rect x="248" y="16" width="106" height="68" rx="18" fill="none" stroke="url(#movaio)" stroke-width="8"/>
      <text x="268" y="72" font-family="system-ui,'Segoe UI',Roboto,sans-serif" font-weight="800" font-size="58" fill="#fbbf24">io</text>
      <text x="358" y="26" font-family="system-ui,sans-serif" font-size="18" fill="var(--mut)">&#8482;</text>
    </svg>
    <span class="brand-badge">MDK · Live Demo</span>
  </div>
  <p class="sub">Build, evaluate, and deploy AI agents — all hosted on Azure Container Apps.</p>
  <div class="grid">
    <a class="card" href="__OPENWEBUI_URL__" target="_blank">
      <h2>💬 OpenWebUI</h2><p>Chat with 12 agents from a dropdown. Voice in (Whisper) + out (TTS).</p>
      <span class="tag">login: mdk-user@movate.dev</span></a>
    <a class="card" href="__PLAYGROUND_URL__" target="_blank">
      <h2>🧪 Chainlit Playground</h2><p>Structured-input UI — drive task agents (ticket-triager, resume-screener) with typed fields + voice.</p>
      <span class="tag">public</span></a>
    <a class="card" href="#control-plane">
      <h2>🎛️ Agent Control Plane</h2><p>See every agent — standalone + each workflow's bundled agents — and enable / deprecate / disable + health-check them live (ADR 090).</p>
      <span class="tag">login: __CP_USER__ / __CP_PASS__</span></a>
    <a class="card" href="__API_URL__/docs" target="_blank">
      <h2>⚙️ Runtime API</h2><p>The OpenAPI surface — agents, skills, contexts, KB, eval, voice.</p>
      <span class="tag">bearer-auth</span></a>
    <a class="card" href="__TEMPORAL_UI_URL__" target="_blank">
      <h2>⏳ Temporal UI</h2><p>Inspect durable workflows — per-run history, pending HUMAN approvals, replay.</p>
      <span class="tag">public · no login</span></a>
    <a class="card" href="__LANGFUSE_URL__" target="_blank">
      <h2>🔭 Langfuse</h2><p>Self-hosted LLM tracing — agent/workflow traces, latency, token cost, per-run drill-down.</p>
      <span class="tag">login: demo@movate.dev / MovateDemo2026!</span></a>
    <a class="card" href="__GRAFANA_URL__" target="_blank">
      <h2>📊 Grafana Dashboards</h2><p>Live runtime metrics from Azure Monitor — requests, CPU, replicas, memory.</p>
      <span class="tag">public · no login</span></a>
  </div>
  <div class="note">
    <b>Postman demo:</b> import <code>postman/movate-core-flow.postman_collection.json</code>, set <code>runtime_url</code> to the Runtime API host and <code>bearer_token</code> to Deva's key — run the folder top to bottom: project → agent → skill → context → KB → validate → eval → voice.
  </div>
  <p class="foot">Ephemeral demo environment · movate-dev · East US 2 · <span id="deployInfo" title="last landing-page deploy (UTC): __DEPLOYED_AT__">deployed __DEPLOYED_AT__</span></p>
</div>

<!-- ===================== AGENT CONTROL PLANE (ADR 090) ===================== -->
<div class="wrap wide" id="cp">
  <div class="cp-head">
    <h1>🎛️ Agent Control Plane</h1>
    <a class="back" href="#">← back to demo</a>
  </div>
  <p class="sub" style="margin-bottom:18px">Operational lifecycle for the runtime's agents (ADR 090). <span class="muted">active</span> = served + in pickers · <span class="muted">deprecated</span> = served but hidden from pickers · <span class="muted">disabled</span> = not served (runs 409). Reversible — unlike delete.</p>
  <div class="bar" id="cpLogin">
    <input id="cpUser" type="text" placeholder="username" autocomplete="username"/>
    <input id="cpPass" type="password" placeholder="password" autocomplete="current-password"/>
    <button class="btn" id="login">Sign in</button>
  </div>
  <div class="bar" id="cpControls" style="display:none">
    <span class="muted">✅ Signed in.</span>
    <button class="btn" id="refresh">↻ Refresh</button>
    <button class="btn" id="logout">Sign out</button>
  </div>
  <div class="msg" id="msg"></div>

  <h2 style="margin:18px 0 6px">Standalone agents</h2>
  <table>
    <thead><tr><th>Agent</th><th>Version</th><th>Role</th><th>Status</th><th>Health</th><th>Actions</th></tr></thead>
    <tbody id="rows"><tr><td colspan="6" class="muted">Sign in to load agents.</td></tr></tbody>
  </table>

  <h2 style="margin:24px 0 6px">Workflow-bundled agents <span class="muted" style="font-weight:400">— the agents each workflow template ships with</span></h2>
  <table>
    <thead><tr><th>Workflow</th><th>Agent</th><th>Version</th><th>Role / model</th><th>Description</th></tr></thead>
    <tbody id="wfRows"><tr><td colspan="5" class="muted">Sign in to load workflow agents.</td></tr></tbody>
  </table>

  <p class="foot">API: <code id="apiUrl">__API_URL__</code> · standalone <code>GET /api/v1/agents</code> · workflow-bundled <code>GET /api/v1/workflow-agents</code> · status changes <code>PATCH /api/v1/agents/{name}/status</code>.</p>
</div>

<script>
  var API_BASE = "__API_URL__".replace(/\/$/, "");
  var CP_TOKEN = "__CP_TOKEN__";
  var CP_USER = "__CP_USER__";
  var CP_PASS = "__CP_PASS__";
  var DEPLOYED_AT = "__DEPLOYED_AT__";
  var AUTH_KEY = "mdk_cp_authed";
  var home = document.getElementById("home");
  var cp = document.getElementById("cp");
  var rows = document.getElementById("rows");
  var wfRows = document.getElementById("wfRows");
  var msgEl = document.getElementById("msg");
  var loginBar = document.getElementById("cpLogin");
  var controlsBar = document.getElementById("cpControls");

  function authed(){ return localStorage.getItem(AUTH_KEY) === "1"; }
  function headers(){ return {"Content-Type":"application/json", "Authorization":"Bearer " + CP_TOKEN}; }
  function msg(text, kind){ msgEl.textContent = text; msgEl.className = "msg " + (kind||""); }
  function esc(s){ return String(s==null?"":s).replace(/[&<>"]/g, function(c){ return {"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;"}[c]; }); }

  // ----- deploy date + live "time since" (footer) -----
  function relTime(iso){
    var t = Date.parse(iso); if(isNaN(t)) return "";
    var s = Math.max(0, Math.floor((Date.now()-t)/1000));
    var d=Math.floor(s/86400), h=Math.floor((s%86400)/3600), m=Math.floor((s%3600)/60);
    var parts=[]; if(d) parts.push(d+"d"); if(h) parts.push(h+"h"); if(d===0) parts.push(m+"m");
    return (parts.join(" ")||"0m") + " ago";
  }
  function tickDeploy(){
    var el=document.getElementById("deployInfo"); if(!el || DEPLOYED_AT.indexOf("__")===0) return;
    var d=DEPLOYED_AT.replace("T"," ").replace("Z","").replace(/:\d\d$/,"");
    el.textContent = "deployed " + d + " UTC · " + relTime(DEPLOYED_AT);
  }
  tickDeploy(); setInterval(tickDeploy, 60000);

  function showAuth(on){
    loginBar.style.display = on ? "none" : "flex";
    controlsBar.style.display = on ? "flex" : "none";
  }

  function route(){
    if(location.hash === "#control-plane"){
      home.style.display = "none"; cp.style.display = "block";
      showAuth(authed());
      if(authed() && rows.children.length <= 1) loadAll();
    } else {
      home.style.display = "block"; cp.style.display = "none";
    }
  }
  window.addEventListener("hashchange", route);

  function doLogin(){
    var u=document.getElementById("cpUser").value.trim();
    var p=document.getElementById("cpPass").value;
    if(u===CP_USER && p===CP_PASS){ localStorage.setItem(AUTH_KEY,"1"); showAuth(true); msg("Signed in.","ok"); loadAll(); }
    else { msg("Invalid username or password.","err"); }
  }
  function doLogout(){
    localStorage.removeItem(AUTH_KEY); showAuth(false);
    rows.innerHTML='<tr><td colspan="6" class="muted">Sign in to load agents.</td></tr>';
    wfRows.innerHTML='<tr><td colspan="5" class="muted">Sign in to load workflow agents.</td></tr>';
    msg("Signed out.","ok");
  }

  async function loadAll(){ await load(); await loadWorkflowAgents(); }

  async function load(){
    if(!authed()){ return; }
    msg("Loading agents…", "ok");
    try{
      var r = await fetch(API_BASE + "/api/v1/agents?health=1", {headers: headers()});
      if(!r.ok){ throw new Error("HTTP " + r.status + " — " + (r.status===401||r.status===403 ? "auth rejected" : await r.text())); }
      var data = await r.json();
      render(data.agents || []);
      msg((data.agents||[]).length + " standalone agents · health probed", "ok");
    }catch(e){ rows.innerHTML = ""; msg("Failed to load: " + e.message + " (check the API allows this origin via MDK_CORS_ALLOWED_ORIGINS)", "err"); }
  }

  async function loadWorkflowAgents(){
    if(!authed()){ return; }
    try{
      var r = await fetch(API_BASE + "/api/v1/workflow-agents", {headers: headers()});
      if(!r.ok){ wfRows.innerHTML = '<tr><td colspan="5" class="muted">workflow-agents endpoint unavailable (HTTP '+r.status+')</td></tr>'; return; }
      var data = await r.json();
      renderWf(data.workflow_agents || []);
    }catch(e){ wfRows.innerHTML = '<tr><td colspan="5" class="muted">Failed: '+esc(e.message)+'</td></tr>'; }
  }

  function statusPill(s){ return '<span class="pill ' + esc(s) + '">' + esc(s) + '</span>'; }
  function healthPill(h){ return '<span class="pill ' + esc(h) + '">' + esc(h) + '</span>'; }

  function render(agents){
    if(!agents.length){ rows.innerHTML = '<tr><td colspan="6" class="muted">No standalone agents.</td></tr>'; return; }
    rows.innerHTML = agents.map(function(a){
      var n = esc(a.name), st = a.status || "active", hl = a.health || "unknown";
      function b(label, target){ var on = st===target ? " on" : ""; return '<button class="btn sm'+on+'" data-act="status" data-name="'+n+'" data-status="'+target+'">'+label+'</button>'; }
      return '<tr>'
        + '<td><b>'+n+'</b></td>'
        + '<td class="muted">'+esc(a.version)+'</td>'
        + '<td class="muted">'+esc(a.role||"—")+'</td>'
        + '<td>'+statusPill(st)+'</td>'
        + '<td>'+healthPill(hl)+'</td>'
        + '<td class="actions">'+b("Active","active")+b("Deprecate","deprecated")+b("Disable","disabled")
        + '<button class="btn sm" data-act="test" data-name="'+n+'">Test</button></td>'
        + '</tr>';
    }).join("");
  }

  function renderWf(items){
    if(!items.length){ wfRows.innerHTML = '<tr><td colspan="5" class="muted">No workflow-bundled agents yet.</td></tr>'; return; }
    wfRows.innerHTML = items.map(function(a){
      return '<tr>'
        + '<td><b>'+esc(a.workflow)+'</b></td>'
        + '<td>'+esc(a.name)+'</td>'
        + '<td class="muted">'+esc(a.version)+'</td>'
        + '<td class="muted">'+esc(a.role||a.model||"—")+'</td>'
        + '<td class="muted">'+esc(a.description||"—")+'</td>'
        + '</tr>';
    }).join("");
  }

  async function setStatus(name, status){
    msg("Setting " + name + " → " + status + "…", "ok");
    try{
      var r = await fetch(API_BASE + "/api/v1/agents/" + encodeURIComponent(name) + "/status",
        {method:"PATCH", headers: headers(), body: JSON.stringify({status: status})});
      if(!r.ok){ throw new Error("HTTP " + r.status + " — " + (r.status===403 ? "key lacks admin scope" : await r.text())); }
      msg(name + " is now " + status, "ok");
      await load();
    }catch(e){ msg("Failed: " + e.message, "err"); }
  }

  async function testHealth(name){
    msg("Probing " + name + " (mock dry-run)…", "ok");
    try{
      var r = await fetch(API_BASE + "/api/v1/agents/" + encodeURIComponent(name) + "/health?probe=run", {headers: headers()});
      var d = await r.json();
      msg(name + ": " + (d.healthy ? "✅ healthy" : "❌ unhealthy — " + (d.detail||"")), d.healthy ? "ok" : "err");
      await load();
    }catch(e){ msg("Failed: " + e.message, "err"); }
  }

  document.getElementById("login").addEventListener("click", doLogin);
  document.getElementById("cpPass").addEventListener("keydown", function(e){ if(e.key==="Enter") doLogin(); });
  document.getElementById("logout").addEventListener("click", doLogout);
  document.getElementById("refresh").addEventListener("click", loadAll);
  rows.addEventListener("click", function(ev){
    var t = ev.target; if(t.tagName !== "BUTTON") return;
    var name = t.getAttribute("data-name");
    if(t.getAttribute("data-act") === "status") setStatus(name, t.getAttribute("data-status"));
    else if(t.getAttribute("data-act") === "test") testHealth(name);
  });

  route();
</script>
</body>
</html>
