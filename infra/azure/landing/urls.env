# Tile target URLs for the movate-dev landing page. Edit here (source of truth),
# then run ./deploy-landing.sh. Override any value via the environment.
# The VM-hosted services (Temporal UI, Langfuse) use stable Azure DNS labels
# (#767) — *.eastus2.cloudapp.azure.com — so a VM rebuild (new IP) doesn't break
# these tiles. The deploy scripts (infra/azure/{temporal,langfuse}-vm) assign the
# label; still plain http (TLS is the remaining hardening on #767).
OPENWEBUI_URL="${OPENWEBUI_URL:-https://movate-dev-openwebui.bluebush-9aec1e70.eastus2.azurecontainerapps.io}"
PLAYGROUND_URL="${PLAYGROUND_URL:-https://movate-dev-playground.bluebush-9aec1e70.eastus2.azurecontainerapps.io}"
GRAFANA_URL="${GRAFANA_URL:-https://movate-dev-grafana-oss.bluebush-9aec1e70.eastus2.azurecontainerapps.io}"
TEMPORAL_UI_URL="${TEMPORAL_UI_URL:-http://movate-dev-temporal.eastus2.cloudapp.azure.com:8080}"
LANGFUSE_URL="${LANGFUSE_URL:-http://movate-dev-langfuse.eastus2.cloudapp.azure.com:3000}"
API_URL="${API_URL:-https://movate-dev-api.bluebush-9aec1e70.eastus2.azurecontainerapps.io}"
