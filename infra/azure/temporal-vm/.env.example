# Copy to .env (gitignored) and fill in — OR let deploy-temporal-vm.sh inject these.
# Reuses the EXISTING shared Azure Postgres Flexible Server (temporal + temporal_visibility DBs).
POSTGRES_SEEDS=movate-dev-pg-mvt.postgres.database.azure.com
POSTGRES_USER=movateadmin
# Pull from Key Vault, do NOT commit:
#   az keyvault secret show --vault-name movate-dev-kv-mvt --name pg-admin-password --query value -o tsv
POSTGRES_PWD=
