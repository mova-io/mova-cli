#!/bin/sh
# No-op as of ADR 066: the CalVer version is DERIVED FROM GIT at build time
# (hatch_build.py + scripts/calver_version.py), so there is no version line to
# bump and re-stage on commit. This hook used to auto-bump pyproject.toml /
# __init__.py / uv.lock — that's exactly the per-commit churn (and worktree-
# propagation breakage) ADR 066 removed. Kept as a harmless no-op so existing
# clones with core.hooksPath=.githooks don't error; safe to delete.
exit 0
