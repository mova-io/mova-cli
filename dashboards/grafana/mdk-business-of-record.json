      "options": {
        "pieType": "pie",
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "values": [
            "value"
          ]
        },
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres-movate"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT workflow AS metric, count(*) AS value FROM workflow_runs GROUP BY workflow ORDER BY value DESC"
        }
      ]
    },
    {
      "id": 4,
      "title": "Run cost over time (USD)",
      "type": "timeseries",
      "datasource": {
        "type": "postgres",
        "uid": "postgres-movate"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres-movate"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('hour',created_at) AS time, sum((metrics::jsonb->>'cost_usd')::float) AS \"cost_usd\" FROM runs WHERE $__timeFilter(created_at) GROUP BY 1 ORDER BY 1"
        }
      ]
    },
    {
      "id": 5,
      "title": "Top agents by total cost (USD)",
      "type": "barchart",
      "datasource": {
        "type": "postgres",
        "uid": "postgres-movate"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres-movate"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT agent, round(sum((metrics::jsonb->>'cost_usd')::float)::numeric,5) AS cost_usd FROM runs WHERE metrics IS NOT NULL GROUP BY agent ORDER BY cost_usd DESC NULLS LAST LIMIT 12"
        }
      ]
    },
    {
      "id": 6,
      "title": "Recent workflow runs",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "postgres-movate"
      },
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres-movate"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT created_at, workflow, status, coalesce(runtime,'native') AS runtime, paused_node_id, workflow_run_id FROM workflow_runs ORDER BY created_at DESC LIMIT 25"
        }
      ]
    }
  ]
