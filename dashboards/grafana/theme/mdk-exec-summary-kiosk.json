{
  "$comment": "TV / kiosk variant of mdk-exec-summary.json for an ops wall or a demo screen. Same metrics + Movate palette, but tuned for a glance-from-across-the-room display: 30s auto-refresh, big single-stat panels, no per-panel triage prose, dark style. Import it, then open with Grafana kiosk mode -- append ?kiosk=tv (toolbar hidden, variables visible) or ?kiosk (full chrome hidden) to the URL, or click the monitor icon in the top bar. Lives under theme/ (not dashboards/grafana/*.json) so the strict anti-drift glob doesn't double-count it; the metric names are identical to the exec dashboard so it can't drift from the catalog. Only references real #518 metrics (mdk.run.cost_usd, mdk.jobs.completed).",
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping mdk's OTel metrics (same source as the exec dashboard).",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "mdk - executive summary (TV / kiosk). Big-glance ops-wall variant of mdk-exec-summary.json. 30s refresh, large stats, Movate palette. Live OTel metrics only (health/wins/risks omitted -- they need the ADR 047 API + small text the wall can't read). Open in kiosk mode (?kiosk=tv).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "type": "stat",
      "id": 1,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 8, "x": 0, "y": 0},
      "title": "Success rate",
      "description": "Live fleet success rate (mdk.jobs.completed). The wall's at-a-glance health proxy.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "max": 1,
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "#D64550", "value": null}, {"color": "#F2A93B", "value": 0.9}, {"color": "#2BB673", "value": 0.98}]},
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "text": {"valueSize": 80}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(increase(mdk_jobs_completed_total{status=\"success\"}[$__range])) / clamp_min(sum(increase(mdk_jobs_completed_total[$__range])), 1)",
          "legendFormat": "success",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 2,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 8, "x": 8, "y": 0},
      "title": "Spend this period",
      "description": "Total LLM spend (mdk.run.cost_usd) over the period.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "#2D6CDF"},
          "unit": "currencyUSD",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "text": {"valueSize": 80}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(increase(mdk_run_cost_usd_total[$__range]))",
          "legendFormat": "spend",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "id": 3,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 9, "w": 8, "x": 16, "y": 0},
      "title": "Runs this period",
      "description": "Total runs (mdk.jobs.completed) over the period.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "fixed", "fixedColor": "#5BC0EB"},
          "unit": "short",
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value",
        "text": {"valueSize": 80}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(increase(mdk_jobs_completed_total[$__range]))",
          "legendFormat": "runs",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "type": "gauge",
      "id": 4,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 11, "w": 8, "x": 0, "y": 9},
      "title": "Error budget remaining",
      "description": "1 - error budget consumed (SLO 99% success). Green comfortable, red exhausted.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "max": 1,
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "#D64550", "value": null}, {"color": "#F2A93B", "value": 0.25}, {"color": "#2BB673", "value": 0.5}]},
          "unit": "percentunit"
        },
        "overrides": []
      },
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "clamp_min(1 - sum(increase(mdk_jobs_completed_total{status!=\"success\"}[$__range])) / clamp_min(0.01 * sum(increase(mdk_jobs_completed_total[$__range])), 1), 0)",
          "legendFormat": "remaining",
          "range": false,
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "id": 5,
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "gridPos": {"h": 11, "w": 16, "x": 8, "y": 9},
      "title": "Spend forecast vs budget",
      "description": "Cumulative spend (mdk.run.cost_usd) + linear projection to period end vs the $5k budget line.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 3, "showPoints": "never", "thresholdsStyle": {"mode": "line"}},
          "thresholds": {"mode": "absolute", "steps": [{"color": "#2BB673", "value": null}, {"color": "#D64550", "value": 5000}]},
          "unit": "currencyUSD"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "projected"},
            "properties": [
              {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "#F2A93B"}}
            ]
          }
        ]
      },
      "options": {
        "legend": {"calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(increase(mdk_run_cost_usd_total[$__range])) - sum(increase(mdk_run_cost_usd_total[$__rate_interval]))",
          "legendFormat": "spend",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(predict_linear(mdk_run_cost_usd_total[7d], 86400 * 30))",
          "legendFormat": "projected",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "vector(5000)",
          "legendFormat": "budget",
          "range": true,
          "refId": "C"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["mdk", "movate", "executive", "kiosk", "tv", "wow-pack"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 2,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      }
    ]
  },
  "time": {"from": "now-30d", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "mdk - executive summary (TV / kiosk)",
  "uid": "mdk-exec-summary-kiosk",
  "version": 1,
  "weekStart": ""
}
