{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the OTLP -> Prometheus stream that carries mdk's OTel metrics. Provisioned automatically by infra/otel-collector/ (uid: prometheus).",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "9.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "mdk runtime overview: per-tenant + per-kind request rate, latency p50/p95/p99, and error rate over the OTel metrics mdk.jobs.completed and mdk.job.duration_ms. Source: src/movate/tracing/metrics.py (METRIC_JOBS_COMPLETED / METRIC_JOB_DURATION_MS). Note: mdk does not export a per-route HTTP metric today (only the job-queue golden signals); the 'route' axis from the brief degrades to 'kind' (job kind), which is what the runtime actually attributes. The tenant template variable is the 'tenant' label carried on mdk.jobs.completed and mdk.jobs.in_flight.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "Throughput (mdk.jobs.completed)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Job completion rate (jobs/sec) split by terminal status, filtered to the selected tenant. From mdk.jobs.completed (status = success / error / safety_blocked / dead_letter).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": {"group": "A", "mode": "normal"}
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "legend": {"calcs": ["lastNotNull", "sum"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum by (status) (rate(mdk_jobs_completed_total{tenant=~\"$tenant\"}[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Throughput by status (selected tenant)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Throughput split by job 'kind' attribute on mdk.jobs.completed for the selected tenant.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 2,
      "options": {
        "legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum by (kind) (rate(mdk_jobs_completed_total{tenant=~\"$tenant\"}[$__rate_interval]))",
          "legendFormat": "{{kind}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Throughput by kind (selected tenant)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 101,
      "panels": [],
      "title": "Latency (mdk.job.duration_ms)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Latency percentiles over the mdk.job.duration_ms histogram (claim -> terminal status). Note: mdk.job.duration_ms attributes are {kind, status} only -- not 'tenant' -- so this panel is fleet-wide; the tenant variable does not filter latency.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 3,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum by (le) (rate(mdk_job_duration_ms_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p50",
          "range": true,
          "refId": "p50"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(mdk_job_duration_ms_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p95",
          "range": true,
          "refId": "p95"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(mdk_job_duration_ms_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "p99",
          "range": true,
          "refId": "p99"
        }
      ],
      "title": "Latency p50 / p95 / p99 (fleet)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "p95 latency split by job kind from mdk.job.duration_ms (kind attribute).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "ms"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 4,
      "options": {
        "legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, kind) (rate(mdk_job_duration_ms_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "{{kind}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "p95 by kind",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 102,
      "panels": [],
      "title": "Error rate (mdk.jobs.completed, status != success)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Error ratio = non-success terminal jobs / all terminal jobs over the window, scoped to the selected tenant. Dead-letters are the status=dead_letter slice.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "max": 1,
          "min": 0,
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 19},
      "id": 5,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(rate(mdk_jobs_completed_total{tenant=~\"$tenant\",status!=\"success\"}[$__rate_interval])) / clamp_min(sum(rate(mdk_jobs_completed_total{tenant=~\"$tenant\"}[$__rate_interval])), 1e-9)",
          "legendFormat": "error rate (all non-success)",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(rate(mdk_jobs_completed_total{tenant=~\"$tenant\",status=\"dead_letter\"}[$__rate_interval])) / clamp_min(sum(rate(mdk_jobs_completed_total{tenant=~\"$tenant\"}[$__rate_interval])), 1e-9)",
          "legendFormat": "dead-letter rate",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "Error rate + dead-letter rate (selected tenant)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["mdk", "movate", "runtime", "adr-031"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": {"selected": false, "text": "All", "value": ".*"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(mdk_jobs_completed_total, tenant)",
        "hide": 0,
        "includeAll": true,
        "label": "tenant",
        "multi": true,
        "name": "tenant",
        "options": [],
        "query": {"query": "label_values(mdk_jobs_completed_total, tenant)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "regex": "",
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "mdk — runtime overview (throughput / latency / errors)",
  "uid": "mdk-runtime-overview",
  "version": 1,
  "weekStart": ""
}
