{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the OTLP -> Prometheus stream that carries mdk's OTel metrics.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "mdk saturation view: worker in-flight depth (mdk.jobs.in_flight) + Postgres pool saturation gauges (mdk.db.pool.size / idle / in_use / waiting / max -- ADR 034 D3). These are the early-warning signals under KEDA autoscale: in-flight rising without throughput catching up = workers stuck; in_use approaching max + sustained non-zero waiting = pool exhaustion (N_pods * pool_max can exceed Azure Postgres max_connections; mdk doctor does the static math, ADR 034 D1). All sources are emitted from src/movate/tracing/metrics.py; pool gauges are flat/zero on the local SQLite backend (no pool).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "In-flight jobs (mdk.jobs.in_flight)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Worker in-flight job count (claimed, not yet terminal) by tenant. Up-down counter -- no _total suffix; bracketed inc/dec in src/movate/runtime/worker.py.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum by (tenant) (mdk_jobs_in_flight{tenant=~\"$tenant\"})",
          "legendFormat": "{{tenant}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "In-flight by tenant",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 101,
      "panels": [],
      "title": "Postgres pool (ADR 034 D3 — mdk.db.pool.*)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Per-pod pool composition: open (size), idle, in-use (size - idle). Observable gauges sampled at OTel collection time.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 2,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(mdk_db_pool_size)",
          "legendFormat": "size (open, fleet)",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(mdk_db_pool_idle)",
          "legendFormat": "idle (fleet)",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(mdk_db_pool_in_use)",
          "legendFormat": "in_use (fleet)",
          "range": true,
          "refId": "C"
        }
      ],
      "title": "Pool composition (fleet)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Pool saturation = in_use / max. Approaches 1.0 -> connection exhaustion imminent on this pod. Computed per pod via service.instance.id-style labels Prometheus adds from the OTel resource (instance label).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never"},
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.7},
              {"color": "red", "value": 0.9}
            ]
          },
          "unit": "percentunit"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 3,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "mdk_db_pool_in_use / clamp_min(mdk_db_pool_max, 1)",
          "legendFormat": "{{instance}} in_use/max",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Per-pod pool saturation (in_use / max)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Callers blocked waiting on the acquire queue (mdk.db.pool.waiting). Sustained non-zero = the pool ceiling is too tight for the offered load; revisit pool_max or pod count.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never"},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 18},
      "id": 4,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(mdk_db_pool_waiting)",
          "legendFormat": "waiting (fleet)",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Pool acquire waiters (early-warning)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["mdk", "movate", "saturation", "queue", "pool", "adr-031", "adr-034"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": {"selected": false, "text": "All", "value": ".*"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(mdk_jobs_in_flight, tenant)",
        "hide": 0,
        "includeAll": true,
        "label": "tenant",
        "multi": true,
        "name": "tenant",
        "options": [],
        "query": {"query": "label_values(mdk_jobs_in_flight, tenant)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "regex": "",
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "mdk — queue & pool saturation",
  "uid": "mdk-queue-and-pool",
  "version": 1,
  "weekStart": ""
}
