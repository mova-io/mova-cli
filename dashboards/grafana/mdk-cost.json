{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the OTLP -> Prometheus stream that carries mdk's OTel metrics.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "mdk LLM cost + token volume over the two cost-related instruments mdk.run.tokens and mdk.run.cost_usd. Source: src/movate/tracing/metrics.py (METRIC_RUN_TOKENS / METRIC_RUN_COST_USD), recorded by record_run_usage() at the runtime edge. Both carry ONE attribute today: 'tenant'. The brief asked for splits by agent and provider, but neither is an attribute on these counters at the OTel layer (the per-agent/per-provider breakdown lives on the agent.execute span attributes instead -- query traces in Jaeger / Langfuse to slice that way). The tenant variable is the only metric-side slicer available.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "LLM cost (mdk.run.cost_usd)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Cumulative LLM cost in USD for the selected tenant over the dashboard window.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "9.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(increase(mdk_run_cost_usd_total{tenant=~\"$tenant\"}[$__range]))",
          "legendFormat": "USD over range",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Total spend (window)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "USD-per-second burn rate for the selected tenant. Multiplied by 3600 gives USD/hr.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 20, "lineWidth": 2, "showPoints": "never"},
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 18, "x": 6, "y": 1},
      "id": 2,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum by (tenant) (rate(mdk_run_cost_usd_total{tenant=~\"$tenant\"}[$__rate_interval]))",
          "legendFormat": "{{tenant}} USD/s",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Spend rate by tenant",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 7},
      "id": 101,
      "panels": [],
      "title": "Token volume (mdk.run.tokens)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Tokens consumed per second by tenant. Counter is total (input + output) -- the OTel instrument does not break direction out as an attribute today, see src/movate/tracing/metrics.py record_run_usage().",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "options": {
        "legend": {"calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum by (tenant) (rate(mdk_run_tokens_total{tenant=~\"$tenant\"}[$__rate_interval]))",
          "legendFormat": "{{tenant}} tok/s",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Tokens/sec by tenant",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "USD per 1k tokens, derived = spend / (tokens / 1000). Useful for spotting drift in average model cost as the workload mix changes.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never"},
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 4,
      "options": {
        "legend": {"calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sum(rate(mdk_run_cost_usd_total{tenant=~\"$tenant\"}[$__rate_interval])) / clamp_min(sum(rate(mdk_run_tokens_total{tenant=~\"$tenant\"}[$__rate_interval])) / 1000, 1e-9)",
          "legendFormat": "USD / 1k tokens",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Effective USD per 1k tokens",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["mdk", "movate", "cost", "adr-031"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Data source",
        "multi": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "type": "datasource"
      },
      {
        "current": {"selected": false, "text": "All", "value": ".*"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(mdk_run_cost_usd_total, tenant)",
        "hide": 0,
        "includeAll": true,
        "label": "tenant",
        "multi": true,
        "name": "tenant",
        "options": [],
        "query": {"query": "label_values(mdk_run_cost_usd_total, tenant)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "regex": "",
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "",
  "title": "mdk — cost (tokens + USD)",
  "uid": "mdk-cost",
  "version": 1,
  "weekStart": ""
}
