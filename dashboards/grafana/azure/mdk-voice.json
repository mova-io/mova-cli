            "query": "AppMetrics\n| where Name == \"mdk.voice.turns\"\n| where TimeGenerated > ago(24h)\n| extend interrupted = tostring(Properties[\"interrupted\"])\n| summarize Total = sum(Sum), Barged = sumif(Sum, interrupted == \"true\")\n| extend BargePct = iff(Total == 0, 0.0, round(100.0 * Barged / Total, 1))\n| project BargePct",
