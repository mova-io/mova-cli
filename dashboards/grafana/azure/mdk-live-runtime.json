          },
          "queryType": "Azure Log Analytics",
          "subscription": "8fab0f8f-b577-45d7-a485-ec32f73b22be",
          "azureLogAnalytics": {
            "resources": [
              "/subscriptions/8fab0f8f-b577-45d7-a485-ec32f73b22be/resourceGroups/movate-dev-rg/providers/Microsoft.OperationalInsights/workspaces/movate-dev-logs"
            ],
            "query": "AppMetrics\n| where Name == \"mdk.jobs.completed\"\n| extend status = tostring(Properties[\"status\"])\n| summarize Jobs = sum(Sum) by status, bin(TimeGenerated, 5m)\n| order by TimeGenerated asc",
            "resultFormat": "time_series"
          }
        }
      ]
