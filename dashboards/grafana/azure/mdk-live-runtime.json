    {
      "type": "timeseries",
      "id": 9,
      "title": "Jobs completed / 5m by status",
      "description": "**Traffic + Errors** (golden signals). Completed jobs per 5m split by terminal status \u2014 `completed` vs `failed` series side by side is the quickest health read on the worker.",
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "ffnrfwjnew5xcc"
      },
      "gridPos": {
        "x": 0,
        "y": 26,
