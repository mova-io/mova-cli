      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "ffnrfwjnew5xcc"
          },
          "queryType": "Azure Log Analytics",
          "subscription": "8fab0f8f-b577-45d7-a485-ec32f73b22be",
          "azureLogAnalytics": {
            "resources": [
              "/subscriptions/8fab0f8f-b577-45d7-a485-ec32f73b22be/resourceGroups/movate-dev-rg/providers/Microsoft.OperationalInsights/workspaces/movate-dev-logs"
            ],
            "query": "AppMetrics\n| where Name == \"mdk.workflow.completed\"\n| where TimeGenerated > ago(24h)\n| extend status = tostring(Properties[\"status\"])\n| summarize total = sum(Sum), ok = sumif(Sum, status == \"success\")\n| extend SuccessPct = iff(total == 0, 0.0, round(100.0 * ok / total, 1))\n| project SuccessPct",
            "resultFormat": "table"
          }
        }
      ]
