          "azureLogAnalytics": {
            "resources": [
              "/subscriptions/8fab0f8f-b577-45d7-a485-ec32f73b22be/resourceGroups/movate-dev-rg/providers/Microsoft.OperationalInsights/workspaces/movate-dev-logs"
            ],
            "query": "AppMetrics\n| where Name == \"mdk.workflow.completed\"\n| where TimeGenerated > ago(24h)\n| summarize Total = sum(Sum)",
