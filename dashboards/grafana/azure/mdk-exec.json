    {
      "type": "stat",
      "id": 2,
      "title": "Automation Success Rate",
      "description": "Workflows completing successfully \u2014 the headline AI-value signal.",
      "datasource": {
        "type": "grafana-azure-monitor-datasource",
        "uid": "ffnrfwjnew5xcc"
      },
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 5
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "red"
              },
              {
                "value": 75,
                "color": "orange"
              },
              {
                "value": 90,
                "color": "green"
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "grafana-azure-monitor-datasource",
            "uid": "ffnrfwjnew5xcc"
          },
          "queryType": "Azure Log Analytics",
          "subscription": "8fab0f8f-b577-45d7-a485-ec32f73b22be",
          "azureLogAnalytics": {
            "resources": [
              "/subscriptions/8fab0f8f-b577-45d7-a485-ec32f73b22be/resourceGroups/movate-dev-rg/providers/Microsoft.OperationalInsights/workspaces/movate-dev-logs"
            ],
            "query": "AppMetrics\n| where Name == \"mdk.workflow.completed\" | where TimeGenerated > ago(30d)\n| extend status = tostring(Properties[\"status\"])\n| summarize total = sum(Sum), ok = sumif(Sum, status == \"success\")\n| project Pct = iff(total == 0, 0.0, round(100.0 * ok / total, 1))",
            "resultFormat": "table"
          }
        }
      ]
    },
