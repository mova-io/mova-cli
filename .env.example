# Provider API keys — only the ones for providers you actually use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_BASE=
GEMINI_API_KEY=

# Mock provider override (used when you pass --mock to `movate run`).
# Must be a JSON object that satisfies your agent's output schema.
MOVATE_MOCK_RESPONSE='{"message": "mock response"}'

# Live-API smoke tests. Set to 1 to enable `pytest -m smoke` against real
# providers. Each test is also gated on the relevant provider key being set.
# MOVATE_SMOKE=1

# v0.4+ — observability
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=

# v0.5+ — server runtime
# MOVATE_DB_URL=postgresql://user:pass@localhost:5432/movate
# MOVATE_TRACER=stdout   # stdout | langfuse | otel | composite
