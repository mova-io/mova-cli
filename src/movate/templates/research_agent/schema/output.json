{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["executive_summary", "key_points", "disagreements", "open_questions"],
  "properties": {
    "executive_summary": { "type": "string", "minLength": 1 },
    "key_points": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "citations"],
        "properties": {
          "claim":     { "type": "string", "minLength": 1 },
          "citations": {
            "type": "array",
            "items": { "type": "integer", "minimum": 1 },
            "uniqueItems": true
          }
        }
      }
    },
    "disagreements":   { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "open_questions":  { "type": "array", "items": { "type": "string", "minLength": 1 } }
  }
}
