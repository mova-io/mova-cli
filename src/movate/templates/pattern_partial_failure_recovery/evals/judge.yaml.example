# LLM-as-judge for the Partial Failure Recovery workflow. Rename to ``judge.yaml`` to enable.
#
# Scores the final ``summary`` against the expected outcome: a completed
# pipeline must read as all three steps done, mentioning a retry only when
# step 2 actually needed one. Used as the CI eval-gate the pattern's
# governance leans on.

method: llm_judge

model:
  provider: anthropic/claude-sonnet-4-6
  params:
    temperature: 0.0

rubric: |
  Score the workflow's final summary against the expected outcome.
    1.0 = summary states all three steps completed and matches the
          expectation about whether step 2 needed a retry
    0.5 = correct completion but wrong/missing retry detail
    0.0 = wrong outcome, contradicts the expectation, or hallucinated

threshold: 0.7
