{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["category", "priority", "routing_queue", "draft_reply", "confidence"],
  "properties": {
    "category": {
      "type": "string",
      "enum": ["billing", "bug", "feature_request", "account", "how_to", "other"]
    },
    "priority": {
      "type": "string",
      "enum": ["p0_urgent", "p1_high", "p2_normal", "p3_low"]
    },
    "routing_queue": {
      "type": "string",
      "enum": ["billing_ops", "engineering", "product", "customer_success", "tier1_support"]
    },
    "draft_reply": { "type": "string", "minLength": 1 },
    "confidence":  { "type": "number", "minimum": 0, "maximum": 1 }
  }
}
