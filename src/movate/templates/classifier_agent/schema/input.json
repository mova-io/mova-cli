{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["text", "labels"],
  "properties": {
    "text": { "type": "string", "minLength": 1 },
    "labels": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 2,
      "uniqueItems": true
    }
  }
}
