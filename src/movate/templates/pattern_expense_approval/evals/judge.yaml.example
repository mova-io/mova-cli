# LLM-as-judge for the Expense Approval workflow. Rename to ``judge.yaml`` to enable.
#
# Scores the final ``summary`` against the expected outcome: an approved expense
# must read as posted-to-ERP (with a posting reference); a rejected expense must
# read as rejected and NOT posted. Used as the CI eval-gate the pattern's
# governance leans on.

method: llm_judge

model:
  provider: anthropic/claude-sonnet-4-6
  params:
    temperature: 0.0

rubric: |
  Score the workflow's final summary against the expected outcome.
    1.0 = summary states the correct outcome (approved+posted with an ERP
          reference, or rejected and not submitted) and matches the expectation
    0.5 = correct outcome but missing the ERP reference / rejection rationale
    0.0 = wrong outcome, contradicts the expectation, or hallucinated

threshold: 0.7
