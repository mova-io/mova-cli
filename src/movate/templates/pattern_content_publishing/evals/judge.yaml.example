# LLM-as-judge for the Content Publishing workflow. Rename to ``judge.yaml`` to enable.
#
# Scores the final ``summary`` against the expected outcome: published content
# must read as having cleared both reviews AND the human approval (with a
# publication reference); stopped content must read as not published, naming
# the stage that stopped it and the reason from the reviewer notes. Used as
# the CI eval-gate the pattern's governance leans on.

method: llm_judge

model:
  provider: anthropic/claude-sonnet-4-6
  params:
    temperature: 0.0

rubric: |
  Score the workflow's final summary against the expected outcome.
    1.0 = correct outcome (published with a reference, or not published with
          the correct stopping stage and reason) matching the expectation
    0.5 = correct outcome but missing the publication reference / the
          stopping stage or reason
    0.0 = wrong outcome (claims published when it was not, or vice versa),
          contradicts the expectation, or hallucinated

threshold: 0.7
