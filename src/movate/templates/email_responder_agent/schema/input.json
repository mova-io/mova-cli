{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["from", "subject", "body", "intent", "tone", "length"],
  "properties": {
    "from":    { "type": "string", "minLength": 1 },
    "subject": { "type": "string", "minLength": 1 },
    "body":    { "type": "string", "minLength": 1 },
    "intent":  { "type": "string", "minLength": 1, "description": "What the sender wants the reply to accomplish." },
    "tone":    {
      "type": "string",
      "enum": ["formal", "professional", "friendly", "concise"]
    },
    "length":  {
      "type": "string",
      "enum": ["one_liner", "short", "medium"]
    }
  }
}
