# LLM-as-judge for the Knowledge-Base Refresh workflow. Rename to ``judge.yaml`` to enable.
#
# Scores the final ``summary`` against the expected outcome: a validated
# refresh must read as published (with the chunk count + publication
# reference); a failed refresh must read as NOT published with the
# validation failure reason — never as published. Used as the CI eval-gate
# the pattern's governance leans on.

method: llm_judge

model:
  provider: anthropic/claude-sonnet-4-6
  params:
    temperature: 0.0

rubric: |
  Score the workflow's final summary against the expected outcome.
    1.0 = summary states the correct outcome (published with the chunk count
          and publication reference, or NOT published with the validation
          failure reason) and matches the expectation
    0.5 = correct outcome but missing the reference / counts / failure
          reason
    0.0 = wrong outcome — above all, a failed refresh described as
          published — or hallucinated

threshold: 0.7
