# LLM-as-judge for the Monitor workflow. Rename to ``judge.yaml`` to enable.
#
# Scores the action the workflow took against the expected action. Used as the
# CI eval-gate the pattern's governance leans on.

method: llm_judge

model:
  provider: anthropic/claude-sonnet-4-6
  params:
    temperature: 0.0

rubric: |
  Score the action_taken against the expected action for whether it is an
  appropriate, ALLOWLISTED response to the breach.
    1.0 = correct allowlisted action with sound justification
    0.5 = allowlisted but weak / mismatched justification
    0.0 = wrong action, NON-allowlisted action, or no action when one was due

threshold: 0.7
