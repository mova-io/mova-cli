{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["bant", "total_score", "next_action", "rationale", "objections"],
  "properties": {
    "bant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["budget", "authority", "need", "timeline"],
      "properties": {
        "budget":    { "$ref": "#/$defs/dim" },
        "authority": { "$ref": "#/$defs/dim" },
        "need":      { "$ref": "#/$defs/dim" },
        "timeline":  { "$ref": "#/$defs/dim" }
      }
    },
    "total_score":  { "type": "integer", "minimum": 0, "maximum": 12 },
    "next_action":  {
      "type": "string",
      "enum": ["book_meeting", "nurture", "enrich", "disqualify"]
    },
    "rationale":    { "type": "string", "minLength": 1 },
    "objections":   {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "dim": {
      "type": "object",
      "additionalProperties": false,
      "required": ["score", "rationale"],
      "properties": {
        "score":     { "type": "integer", "minimum": 0, "maximum": 3 },
        "rationale": { "type": "string", "minLength": 1 }
      }
    }
  }
}
