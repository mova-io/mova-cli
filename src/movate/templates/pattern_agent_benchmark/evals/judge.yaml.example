# LLM-as-judge for the Agent Benchmark workflow. Rename to ``judge.yaml`` to enable.
#
# Scores the final ``summary`` against the expected outcome: the summary
# must name a winner (a or b), carry a comparative reason, and state that
# the verdict was recorded (with the benchmark reference). Used as the CI
# eval-gate the pattern's governance leans on.

method: llm_judge

model:
  provider: anthropic/claude-sonnet-4-6
  params:
    temperature: 0.0

rubric: |
  Score the workflow's final summary against the expected outcome.
    1.0 = names exactly one winner, gives a comparative rationale that
          engages with both candidates, and confirms the recorded verdict
          with a reference
    0.5 = names a winner but the rationale ignores one candidate or the
          record/reference is missing
    0.0 = no decisive winner, contradicts the expectation, or hallucinated

threshold: 0.7
