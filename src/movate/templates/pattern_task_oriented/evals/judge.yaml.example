# LLM-as-judge for the Task-Oriented workflow. Rename to ``judge.yaml`` to enable.
#
# Scores the workflow's final ``answer`` against the expected answer. Used as
# the CI eval-gate the pattern's governance leans on.

method: llm_judge

model:
  provider: anthropic/claude-sonnet-4-6
  params:
    temperature: 0.0

rubric: |
  Score the workflow's final answer against the expected answer for whether it
  correctly synthesizes BOTH task branches into a coherent response.
    1.0 = answer reflects both branches accurately and coherently
    0.5 = answer reflects one branch, or is partially correct
    0.0 = answer is wrong, missing both branches, or hallucinated

threshold: 0.7
