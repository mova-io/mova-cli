{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["match_score", "strengths", "gaps", "interview_questions", "recommendation", "rationale"],
  "properties": {
    "match_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "strengths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "gaps": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "interview_questions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "recommendation": {
      "type": "string",
      "enum": ["advance", "phone_screen", "pass", "unsure"]
    },
    "rationale": { "type": "string", "minLength": 1 }
  }
}
