# LLM-as-judge for the ITSM Service Request workflow. Rename to ``judge.yaml`` to enable.
#
# Scores the final ``summary`` against the expected outcome: a provisioned
# request must read as fulfilled (with a fulfilment reference); a rejected
# request must read as rejected and NOT provisioned. Used as the CI eval-gate
# the pattern's governance leans on.

method: llm_judge

model:
  provider: anthropic/claude-sonnet-4-6
  params:
    temperature: 0.0

rubric: |
  Score the workflow's final summary against the expected outcome.
    1.0 = summary states the correct outcome (provisioned with a fulfilment
          reference, or rejected and nothing provisioned) and matches the
          expectation
    0.5 = correct outcome but missing the fulfilment reference / rejection
          rationale
    0.0 = wrong outcome, contradicts the expectation, or hallucinated

threshold: 0.7
