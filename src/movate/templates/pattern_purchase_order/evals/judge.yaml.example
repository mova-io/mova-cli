# LLM-as-judge for the Purchase Order workflow. Rename to ``judge.yaml`` to enable.
#
# Scores the final ``summary`` against the expected outcome: a created PO
# must read as ordered (with a PO reference); a rejected order must read as
# rejected and NOT ordered. Used as the CI eval-gate the pattern's
# governance leans on.

method: llm_judge

model:
  provider: anthropic/claude-sonnet-4-6
  params:
    temperature: 0.0

rubric: |
  Score the workflow's final summary against the expected outcome.
    1.0 = summary states the correct outcome (purchase order created with a
          PO reference, or rejected and nothing ordered) and matches the
          expectation
    0.5 = correct outcome but missing the PO reference / rejection rationale
    0.0 = wrong outcome, contradicts the expectation, or hallucinated

threshold: 0.7
